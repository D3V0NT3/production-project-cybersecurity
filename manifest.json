{
  "manifest_version": 3,
  "name": "Phishing Detection System (Banner Demo)",
  "version": "1.0",
  "permissions": ["tabs", "storage"],
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  "action": {
    "default_popup": "popup.html"
  }
}